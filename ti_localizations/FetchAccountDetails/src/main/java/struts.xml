<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC

   "-//Apache Software Foundation//DTD Struts Configuration 2.3//EN"

   "http://struts.apache.org/dtds/struts-2.3.dtd">
 
<!-- <!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 

	2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd"> -->
<struts>
<constant name="struts.enable.DynamicMethodInvocation" value="false" />
<constant name="struts.devMode" value="false" />
<constant name="struts.custom.i18n.resources" value="in.co.FIRC.resources.ApplicationResources" />
<constant name="struts.ui.theme" value="simple" />
 
	<package name="default" extends="struts-default,json-default"

		namespace="/">
 
		<global-results>
<result name="Exception">/view/common/system_error.jsp</result>
</global-results>
 
		<action name="home"

			class="com.in.fetchAccount.action.FetchAccountDetailsAction" method="landingPage">
<result name="success">/view/accountDetails/getAccountDetailsForm.jsp</result>
</action>
 
 
		<action name="fetchAccountSearch"

			class="com.in.fetchAccount.action.FetchAccountDetailsAction" method="submitAccountDetails">
<result name="success">/view/accountDetails/getAccountDetailsForm.jsp</result>
<result name="error">/view/accountDetails/getAccountDetailsForm.jsp</result>
</action>
</package>
</struts>